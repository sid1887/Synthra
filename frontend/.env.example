# Synthra Frontend Environment Variables

# API Gateway (Main API service)
REACT_APP_API_URL=http://localhost:8000

# Vision Service (Image detection and OCR)
REACT_APP_VISION_URL=http://localhost:8001

# Core Service (HDL generation)
REACT_APP_CORE_URL=http://localhost:8002

# Simulator Service (SPICE/HDL simulation)
REACT_APP_SIMULATOR_URL=http://localhost:8003

# SVE Service (Schematic component library)
REACT_APP_SVE_URL=http://localhost:8005

# Docs Service (PDF, BOM, Gerber generation)
REACT_APP_DOCS_URL=http://localhost:8006

# Realtime Service (WebSocket for live collaboration)
REACT_APP_REALTIME_URL=http://localhost:8007

# Frontend settings
REACT_APP_ENV=development
REACT_APP_DEBUG=true
